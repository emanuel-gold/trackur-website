---
layout: layout.njk
pageTitle: "Better Tools for Better Teams"
pageDescription: "Join 10,000+ teams using Canopy to collaborate smarter. Start your free trial today."
permalink: false
---

{# ── HERO ── #}
<section class="mt-10 sm:mt-16 lg:mt-24">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
    <div>
      <div class="inline-flex items-center gap-2 px-3 py-1.5 border-theme rounded-theme-sm bg-accent-surface text-accent text-xs font-mono font-medium mb-6"
           style="animation: fadeInUp 0.6s ease-out both">
        <span class="size-1.5 rounded-theme-sm bg-accent animate-pulse"></span>
        Trusted by 10,000+ teams
      </div>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl tracking-tight text-text-primary leading-[0.95]"
          style="animation: fadeInUp 0.6s ease-out 0.1s both">
        Your team deserves<br><span class="text-accent">better tools.</span>
      </h1>
      <p class="mt-6 text-lg/7 text-text-secondary max-w-lg"
         style="animation: fadeInUp 0.6s ease-out 0.2s both">
        Stop wrestling with scattered data and siloed teams. Canopy gives every team member the context they need to move fast and make great decisions.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3"
           style="animation: fadeInUp 0.6s ease-out 0.3s both">
        <a href="/pricing/" class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold bg-accent text-text-inverse rounded-theme-lg hover:bg-accent-hover shadow-theme hover:shadow-theme-lg transition-theme">
          Start Your Free Trial
          <svg class="ml-2 size-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/about/" class="inline-flex items-center justify-center px-6 py-4 text-base font-medium border-theme text-text-primary rounded-theme-lg hover:border-accent hover:text-accent transition-theme">
          Learn More
        </a>
      </div>
      <p class="mt-4 text-xs text-text-muted" style="animation: fadeInUp 0.6s ease-out 0.4s both">
        No credit card required &middot; 14-day free trial &middot; Cancel anytime
      </p>
    </div>
    <div class="relative" style="animation: fadeInUp 0.8s ease-out 0.3s both">
      <div class="overflow-hidden rounded-theme-2xl shadow-theme-xl border-theme">
        <img src="/images/photos/image-1.jpg" alt="Teams collaborating on Canopy" class="w-full aspect-4/3 object-cover" />
      </div>
      {# Floating stat card #}
      <div class="absolute -bottom-4 -left-4 sm:-bottom-6 sm:-left-6 bg-bg border-theme rounded-theme-xl p-4 shadow-theme-lg"
           style="animation: fadeInUp 0.6s ease-out 0.6s both">
        <div class="flex items-center gap-3">
          <div class="size-10 flex items-center justify-center rounded-theme-lg bg-accent-light text-accent">
            <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div>
            <p class="text-xs text-text-muted">Avg. time saved</p>
            <p class="text-lg font-semibold text-text-primary">4.2 hrs/week</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{# ── SOCIAL PROOF STATS ── #}
<section class="mt-20 sm:mt-28">
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
    {% set stats = [
      { "value": "10,000+", "label": "Teams worldwide", "icon": "M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" },
      { "value": "99.9%", "label": "Uptime SLA", "icon": "M22 11.08V12a10 10 0 1 1-5.93-9.14" },
      { "value": "4.9/5", "label": "Customer rating", "icon": "M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" }
    ] %}
    {% for stat in stats %}
    <div class="p-6 sm:p-8 border-theme rounded-theme-xl bg-surface text-center hover:shadow-theme transition-theme"
         style="animation: fadeInUp 0.5s ease-out {{ 0.1 * loop.index }}s both">
      <div class="size-12 flex items-center justify-center rounded-theme-lg bg-accent-light text-accent mx-auto mb-4">
        <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="{{ stat.icon }}"/>{% if loop.first %}<circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>{% elif loop.index == 2 %}<path d="M16.24 7.76L22 2"/>{% endif %}</svg>
      </div>
      <p class="font-display text-3xl sm:text-4xl tracking-tight text-text-primary">{{ stat.value }}</p>
      <p class="mt-1 text-sm text-text-secondary">{{ stat.label }}</p>
    </div>
    {% endfor %}
  </div>
</section>

{# ── 3 BENEFITS ── #}
<section class="mt-20 sm:mt-28">
  <div class="max-w-2xl mx-auto text-center mb-12">
    <h2 class="font-display text-3xl sm:text-4xl tracking-tight text-text-primary">Everything your team needs</h2>
    <p class="mt-3 text-text-secondary">One platform. Zero switching costs. Infinite possibilities.</p>
  </div>
  {% set benefits = [
    { "title": "Unified Workspace", "desc": "Docs, tasks, data, and conversations — all in one place. Your team never loses context again.", "iconPath": "M4 5a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V5zM4 13a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v6a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-6zM16 13a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v6a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-6z" },
    { "title": "AI That Actually Helps", "desc": "Smart search, auto-tagging, and predictive insights that get better the more your team uses Canopy.", "iconPath": "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.547A3.374 3.374 0 0 0 14 18.469V19a2 2 0 1 1-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" },
    { "title": "Enterprise Security", "desc": "SOC 2 Type II, SSO, SAML, audit logs, and role-based access. Built for the most demanding security teams.", "iconPath": "M12 15v2m-6 4h12a2 2 0 0 0 2-2v-6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2zm10-10V7a4 4 0 0 0-8 0v4h8z" }
  ] %}
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
    {% for b in benefits %}
    <div class="relative p-6 sm:p-8 border-theme rounded-theme-xl bg-surface group hover:shadow-theme-lg transition-theme overflow-hidden">
      <div class="absolute top-0 right-0 w-32 h-32 bg-accent/[0.03] rounded-full -translate-y-1/2 translate-x-1/2 group-hover:scale-150 transition-transform duration-500"></div>
      <div class="relative">
        <div class="size-10 flex items-center justify-center rounded-theme-lg bg-accent-light text-accent mb-5">
          <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="{{ b.iconPath }}"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary">{{ b.title }}</h3>
        <p class="mt-2 text-sm/6 text-text-secondary">{{ b.desc }}</p>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

{# ── TESTIMONIAL ── #}
<section class="mt-20 sm:mt-28">
  <div class="p-8 sm:p-12 border-theme rounded-theme-2xl bg-bg-alt relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-1 bg-accent/20"></div>
    <div class="max-w-3xl mx-auto text-center">
      <svg class="size-10 text-accent/30 mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z"/></svg>
      <blockquote>
        <p class="text-lg sm:text-xl/8 font-medium text-text-primary italic">
          &ldquo;We evaluated 12 different tools before choosing Canopy. Six months in, our cross-functional teams are shipping 40% faster and our quarterly planning went from a week-long nightmare to a two-day breeze.&rdquo;
        </p>
        <footer class="mt-6 flex items-center justify-center gap-4">
          <div class="size-12 overflow-hidden rounded-theme-lg">
            <img src="/images/photos/image-2.jpg" alt="David Park" class="w-full h-full object-cover" />
          </div>
          <div class="text-left">
            <p class="text-sm font-semibold text-text-primary">David Park</p>
            <p class="text-sm text-text-muted">VP of Engineering, Veritas Systems</p>
          </div>
        </footer>
      </blockquote>
    </div>
  </div>
</section>

{# ── TRUST BADGES ── #}
<section class="mt-16 sm:mt-20 mb-8">
  <div class="text-center">
    <p class="text-xs font-mono text-text-muted uppercase tracking-widest mb-6">Trusted & Certified</p>
    <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-12">
      {% set badges = ["SOC 2 Type II", "GDPR Ready", "ISO 27001", "99.9% SLA"] %}
      {% for badge in badges %}
      <div class="flex items-center gap-2 text-text-muted">
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span class="text-sm font-medium">{{ badge }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ── BOTTOM CTA ── #}
<section class="mt-12 mb-12">
  <div class="p-8 sm:p-12 bg-accent rounded-theme-2xl text-center">
    <h2 class="font-display text-3xl sm:text-4xl tracking-tight text-text-inverse">Ready to transform your team?</h2>
    <p class="mt-3 text-text-inverse/70 max-w-lg mx-auto">Join thousands of teams who've already made the switch. Your 14-day free trial starts now.</p>
    <a href="/pricing/" class="mt-6 inline-flex items-center px-8 py-4 text-base font-semibold bg-bg text-accent rounded-theme-lg hover:shadow-theme-xl transition-theme">
      Start Your Free Trial
      <svg class="ml-2 size-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<style>
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
</style>
