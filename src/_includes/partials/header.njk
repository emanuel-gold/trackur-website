{% set isHomePage = (page.url == "/") %}

<header class="relative z-50 pt-6 pb-4">
  <div class="flex items-center justify-between">
    {# Logo / Wordmark #}
    <a href="/" class="flex items-center gap-2 group no-underline">
      <img class="w-10" src="/images/Trackur Logo.svg" alt="Trackur logo - Home" width="40" height="40">
      </img>
      <span class="font-display text-xl sm:text-2xl font-semibold tracking-tight text-text-primary">
        trackur.app
      </span>
    </a>

    {# Desktop Navigation #}
    <nav class="hidden md:flex items-center gap-1">
      {% for item in navigation %}
      <a
        href="{{ item.href }}"
        class="{% if page.url == item.href %}text-accent font-semibold{% else %}text-text-secondary hover:text-text-primary{% endif %} px-3 py-2 text-sm/5 font-medium transition-colors"
      >
        {{ item.label }}
      </a>
      {% endfor %}

      {# Theme switcher — only in dev mode #}
      {% if site.themeDevMode %}
      <button
        type="button"
        id="site-theme-switcher"
        aria-label="Switch theme"
        class="ml-1 px-3 py-1.5 text-xs font-mono font-medium border-theme rounded-theme text-text-muted hover:text-text-primary hover:border-accent transition-theme"
      >
        <span data-theme-label>{{ site.theme | capitalize }}</span>
      </button>
      {% endif %}

      {# Dark mode toggle #}
      <button
        type="button"
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="ml-1 size-9 flex items-center justify-center rounded-theme border-theme text-text-muted hover:text-text-primary hover:border-accent transition-theme"
      >
        <svg id="theme-icon-sun" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
          class="size-4 fill-none stroke-current dark:hidden">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
        <svg id="theme-icon-moon" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
          class="hidden size-4 fill-none stroke-current dark:block">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>

      {# CTA Button #}
      <a href="https://my.trackur.app" class="ml-3 inline-flex items-center px-4 py-2 text-sm font-semibold rounded-theme bg-accent text-text-inverse hover:bg-accent-hover transition-theme">
        Get started
      </a>
    </nav>

    {# Mobile nav buttons #}
    <div class="flex items-center gap-2 md:hidden">
      {% if site.themeDevMode %}
      <button
        type="button"
        id="site-theme-switcher-mobile"
        aria-label="Switch theme"
        class="px-2 py-1.5 text-xs font-mono font-medium border-theme rounded-theme text-text-muted"
      >
        <span data-theme-label>{{ site.theme | capitalize }}</span>
      </button>
      {% endif %}
      <button
        type="button"
        id="theme-toggle-mobile"
        aria-label="Toggle dark mode"
        class="size-9 flex items-center justify-center rounded-theme border-theme text-text-muted"
      >
        <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
          class="size-4 fill-none stroke-current dark:hidden">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
        <svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
          class="hidden size-4 fill-none stroke-current dark:block">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>
      <button
        type="button"
        id="mobile-nav-button"
        class="size-9 flex items-center justify-center rounded-theme border-theme text-text-muted"
      >
        <svg class="size-5 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  {# Mobile nav backdrop #}
  <div
    id="mobile-nav-backdrop"
    class="fixed inset-0 z-50 bg-surface-overlay hidden opacity-0 transition-opacity duration-150"
  ></div>

  {# Mobile nav panel #}
  <div
    id="mobile-nav-panel"
    class="fixed inset-x-4 top-4 z-50 border-theme bg-bg p-6 hidden scale-95 opacity-0 transition duration-150 shadow-theme-xl rounded-theme-xl"
  >
    <div class="flex flex-row-reverse items-center justify-between mb-6">
      <button type="button" id="mobile-nav-close" aria-label="Close menu" class="size-9 flex items-center justify-center rounded-theme border-theme">
        <svg viewBox="0 0 24 24" aria-hidden="true" class="size-5 stroke-current" fill="none" stroke-width="2" stroke-linecap="round">
          <path d="M18 6 6 18M6 6l12 12" />
        </svg>
      </button>
      <span class="font-display text-lg text-text-primary">Menu</span>
    </div>
    <nav>
      <ul class="space-y-1">
        {% for item in navigation %}
        <li>
          <a href="{{ item.href }}" class="mobile-nav-link block py-3 px-3 text-base font-medium text-text-primary hover:bg-accent-surface hover:text-accent rounded-theme transition-theme">
            {{ item.label }}
          </a>
        </li>
        {% endfor %}
        <li class="pt-3">
          <a href="https://my.trackur.app" class="mobile-nav-link block py-3 px-3 text-base font-semibold text-center bg-accent text-text-inverse rounded-theme">
            Get started
          </a>
        </li>
      </ul>
    </nav>
  </div>

  {# Subtle divider #}
  <div class="mt-4 border-t border-border-default"></div>
</header>
