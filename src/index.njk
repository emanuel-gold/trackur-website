---
layout: layout.njk
---

{# ═══════════════════════════════════════
   SECTION 1: HERO
   ═══════════════════════════════════════ #}
<section class="mt-12 sm:mt-20 lg:mt-28">
  <div class="flex flex-col lg:flex-row lg:items-center lg:gap-12">
    <div class="lg:w-1/2 shrink-0">
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl tracking-tight text-text-primary leading-[0.9]">
        Your job search,<br>
        <span class="text-accent">without the<br class="sm:hidden"> spreadsheet.</span>
      </h1>
      <p class="mt-6 sm:mt-8 max-w-xl text-base/7 sm:text-lg/8 text-text-secondary font-light">
        Free and open-source job application tracker. Visualize each application's progress &amp; plan what's next, and what fell through—all on one screen.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a href="https://my.trackur.app" class="inline-flex items-center px-6 py-3 text-sm font-semibold rounded-theme bg-accent text-text-inverse hover:bg-accent-hover transition-theme">
          Get started for free
        </a>
        <a href="/pricing#free-tier-promise" class="text-xs font-mono text-text-caption tracking-wide uppercase">
        Free Tier Promise
        </a>
      </div>
    </div>

    {# App screenshot placeholder #}
    <div class="mt-8 lg:mt-0 lg:w-1/2 relative overflow-hidden rounded-theme-xl border-theme">
      <div class="aspect-video bg-surface-muted flex items-center justify-center">
        <div class="text-center px-4">
          <p class="font-mono text-xs text-text-muted tracking-wide uppercase">App screenshot</p>
          <p class="mt-1 text-sm text-text-muted">Replace with a screenshot of the trackur dashboard</p>
        </div>
      </div>
    </div>
  </div>
</section>

{# ═══════════════════════════════════════
   SECTION 2: FEATURES
   ═══════════════════════════════════════ #}
<section class="mt-24 sm:mt-32">
  <div class="max-w-2xl">
    <h2 class="font-display text-3xl sm:text-5xl tracking-tight text-text-primary">Stop using spreadsheets.</h2>
    <p class="mt-4 text-text-secondary text-base/7">
      Spreadsheets suck. Trackur gives you a clean, visual dashboard to manage your job applications. Stop wrestling with rows and columns and focus on applying.
    </p>
  </div>
  <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-6">
    {% for feature in features %}
    <div class="p-6 border-theme rounded-theme-xl bg-surface shadow-theme-sm hover:shadow-theme transition-theme group">
      <div class="size-10 flex items-center justify-center rounded-theme-lg bg-accent-light text-accent mb-4">
        {% if feature.icon == "layers" %}
        <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path d="m12 2 10 6.5v7L12 22 2 15.5v-7z" stroke-linejoin="round"/><path d="M12 22v-7" stroke-linecap="round"/><path d="m22 8.5-10 7-10-7" stroke-linejoin="round"/></svg>
        {% elif feature.icon == "search" %}
        <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {% elif feature.icon == "users" %}
        <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" stroke-linecap="round" stroke-linejoin="round"/><polyline points="7 10 12 15 17 10" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="15" x2="12" y2="3" stroke-linecap="round"/></svg>
        {% endif %}
      </div>
      <h3 class="text-lg font-semibold text-text-primary">{{ feature.title }}</h3>
      <p class="mt-2 text-sm/6 text-text-secondary">{{ feature.description }}</p>
    </div>
    {% endfor %}
  </div>
</section>

{# ═══════════════════════════════════════
   SECTION 3: HOW IT WORKS
   ═══════════════════════════════════════ #}
<section class="mt-24 sm:mt-32">
  <h2 class="font-display text-3xl sm:text-5xl tracking-tight text-text-primary">Three steps to a smoother job hunt:</h2>
  <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-8">
    {% for step in steps %}
    <div class="text-center sm:text-left">
      <span class="font-display text-6xl sm:text-7xl text-accent/80">{{ step.number }}</span>
      <h3 class="mt-2 text-xl font-semibold text-text-primary">{{ step.title }}</h3>
      <p class="mt-3 text-md/6 text-text-secondary">{{ step.description }}</p>
    </div>
    {% endfor %}
  </div>
</section>

{# ═══════════════════════════════════════
   SECTION 4: LATEST FROM THE BLOG
   ═══════════════════════════════════════ #}
