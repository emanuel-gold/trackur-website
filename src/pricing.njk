{# Hero — FREE in huge letters #}
<section class="mt-12 sm:mt-20 text-center max-w-3xl mx-auto">
  <h1 class="font-display text-7xl sm:text-8xl lg:text-9xl tracking-tight text-text-primary leading-none">
    Free.
  </h1>
  <p class="mt-6 text-lg sm:text-xl text-text-secondary">You've got enough to worry about while job hunting.<br>You pay nothing for the core features of this app for as long as it exists.</p>
  <div class="mt-8">
    <a href="#" class="inline-flex items-center px-8 py-3.5 text-base font-semibold rounded-theme bg-accent text-text-inverse hover:bg-accent-hover transition-theme">
      Open app
    </a>
  </div>
</section>

